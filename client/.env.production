# Production - Set to your cPanel server URL
# Example: https://yourdomain.com or https://api.yourdomain.com
VITE_API_URL=https://s-h-co-server.neophrondev.in

# Publishable Razorpay key id (safe to expose to browser)
# VITE_RAZORPAY_KEY_ID=rzp_live_...
# Pay-only (sticky banner) amount in paise (₹199 => 19900)
# VITE_RAZORPAY_PAY_AMOUNT_PAISE=19900
# Strike-through "old price" shown in sticky banner (₹999 => 99900)
# VITE_RAZORPAY_PAY_OLD_AMOUNT_PAISE=99900
